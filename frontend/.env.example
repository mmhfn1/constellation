# Optional. If set, the app talks to a live FastAPI backend (backend/app.py)
# over REST — use this for local dev against `uvicorn app:app --reload`, or
# a production deploy where you've hosted the backend yourself.
#
# If left unset (the default for a GitHub Pages build), the app reads the
# precomputed JSON bundled in frontend/public/data/ instead and runs fully
# self-contained, with no backend required. See the README for details.
VITE_API_BASE_URL=http://localhost:8000
